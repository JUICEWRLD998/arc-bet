generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Market {
  id              Int      @id @default(autoincrement())
  slug            String   @unique
  title           String
  categories      String[]
  yesLabel        String   @map("yes_label")
  noLabel         String   @map("no_label")
  topProbability  Float    @map("top_probability")
  oddsYes         Int      @map("odds_yes")
  oddsNo          Int      @map("odds_no")
  outcomes        Json
  volume          Float    @default(0)
  volume24h       Float    @default(0) @map("volume_24h")
  liquidity       Float    @default(0)
  predScopeUrl    String   @default("") @map("predscope_url")
  syncedAt        DateTime @default(now()) @map("synced_at")
  onChainMarketId Int?     @map("on_chain_market_id")

  @@map("markets")
}
